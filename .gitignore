# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# migration data — contains real user data, never commit
/migration/snapshots/

# typescript
*.tsbuildinfo
next-env.d.ts

# Pre-mutation snapshots from scripts/fix-lbs-kg-anomalies.ts. Each
# backup contains full workout JSON for affected rows.
/migration/lbs-kg-fix-backups/

# Pre-mutation backups from scripts/normalize-muscle-snapshots.ts
# (the affected rows' id + prior muscle_groups_snapshot value).
/migration/muscle-snapshot-backups/

# Pre-mutation backups from scripts/normalize-muscle-taxonomy.ts.
/migration/muscle-taxonomy-backups/

# Playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/migration/exercise-merge-backups/

# Pre-mutation backups from scripts/fix-duplicate-workout-2026-07-14.ts
/migration/duplicate-workout-backups/
